#!/usr/bin/env bash
# connect-db — Start Oracle container, wait for readiness, connect via SQL*Plus
#
# Usage:
#   connect-db                    # Interactive login
#   connect-db --from schema.sql  # Run SQL file

set -euo pipefail

# --- Config ---
readonly CONTAINER_NAME="oracledb"
readonly DEFAULT_HOST="localhost"
readonly DEFAULT_PORT="1521"
readonly DEFAULT_SERVICE="FREEPDB1"
readonly MAX_WAIT=120
readonly POLL_INTERVAL=2

# --- Oracle environment ---
_oracle_bin=""

_detect_distro_for_hint() {
    if [[ -r /etc/os-release ]]; then
        # shellcheck source=/dev/null
        source /etc/os-release
        echo "${ID:-unknown}"
    else
        echo "unknown"
    fi
}

_check_ic_deps() {
    local bin="$1"
    local missing
    missing="$(ldd "$bin" 2>/dev/null | grep 'not found' | awk '{print $1}' || true)"
    [[ -z "$missing" ]] && return 0

    local libdir=""
    if [[ -d /usr/lib/x86_64-linux-gnu ]]; then
        libdir="/usr/lib/x86_64-linux-gnu"
    elif [[ -d /usr/lib64 ]]; then
        libdir="/usr/lib64"
    elif [[ -d /lib64 ]]; then
        libdir="/lib64"
    fi

    # Debian Trixie transition: libaio.so.1 -> libaio.so.1t64
    if echo "$missing" | grep -q 'libaio.so.1' && [[ -n "$libdir" ]]; then
        if [[ -f "${libdir}/libaio.so.1t64" && ! -f "${libdir}/libaio.so.1" ]]; then
            echo "[>] Creating libaio compat symlink for Debian trixie..."
            sudo ln -s "${libdir}/libaio.so.1t64" "${libdir}/libaio.so.1" 2>/dev/null && {
                echo "[✓] libaio compat symlink created"
                return 0
            }
        fi
    fi

    # Re-test after symlink
    missing="$(ldd "$bin" 2>/dev/null | grep 'not found' | awk '{print $1}' || true)"
    [[ -z "$missing" ]] && return 0

    echo "[✗] Missing shared libraries for sqlplus:"
    printf '    %s\n' "$missing"
    if echo "$missing" | grep -q 'libaio'; then
        case "$(_detect_distro_for_hint)" in
            debian|ubuntu|linuxmint|kali)
                echo "[>] Fix: sudo apt-get install -y libaio1"
                echo "[>]   On Debian Trixie also try: sudo apt-get install -y libaio1t64"
                ;;
            fedora)
                echo "[>] Fix: sudo dnf install -y libaio"
                ;;
            arch)
                echo "[>] Fix: sudo pacman -S libaio"
                ;;
            opensuse)
                echo "[>] Fix: sudo zypper install -y libaio1"
                ;;
            *)
                echo "[>] Fix: Install the 'libaio' package for your distro"
                ;;
        esac
    fi
    echo "[>] Or re-run: ./install.sh"
    exit 1
}

_setup_oracle_env() {
    local install_dir="${HOME}/.local/oracle"
    local ic_dir=""
    if command -v sqlplus &>/dev/null; then
        _oracle_bin="$(command -v sqlplus)"
        return 0
    fi
    ic_dir="$(find "$install_dir" -maxdepth 1 -type d -name 'instantclient_*' 2>/dev/null | head -n1)"
    if [[ -n "$ic_dir" && -x "${ic_dir}/sqlplus" ]]; then
        export ORACLE_HOME="$ic_dir"
        export LD_LIBRARY_PATH="${ic_dir}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
        export PATH="${ic_dir}:${PATH}"
        _oracle_bin="${ic_dir}/sqlplus"
        return 0
    fi
    echo "[✗] sqlplus not found. Run ./install.sh first."
    exit 1
}

_check_oracle_container() {
    if ! podman container exists "$CONTAINER_NAME" 2>/dev/null; then
        echo "[✗] Oracle container '$CONTAINER_NAME' does not exist."
        echo "[>] Please run ./install.sh first to set up the container."
        exit 1
    fi

    local running
    running="$(podman inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)"
    if [[ "$running" != "true" ]]; then
        echo "[>] Starting Oracle container '$CONTAINER_NAME'..."
        podman start "$CONTAINER_NAME" >/dev/null
        echo "[✓] Oracle container started."
    fi
}

wait_for_oracle() {
    echo "[>] Waiting for Oracle to accept connections..."
    local attempts=0
    local result
    while [[ $attempts -lt $MAX_WAIT ]]; do
        if result="$(podman exec -i "$CONTAINER_NAME" sqlplus -s / as sysdba 2>&1 <<'EOF'
WHENEVER SQLERROR EXIT 1;
WHENEVER OSERROR EXIT 1;
SET PAGESIZE 0 FEEDBACK OFF VERIFY OFF HEADING OFF ECHO OFF
SELECT COUNT(*) FROM v$pdbs WHERE name='FREEPDB1' AND open_mode='READ WRITE';
EXIT;
EOF
)"; then
            if [[ "$(echo "$result" | tr -d '[:space:]')" == "1" ]]; then
                printf "\n"
                echo "[✓] Oracle is ready"
                return 0
            fi
        fi
        ((attempts++))
        sleep "$POLL_INTERVAL"
        printf "\r[>] Waiting... (%d/%d)" "$attempts" "$MAX_WAIT"
    done
    printf "\n"
    echo "[✗] Oracle did not become ready after ${MAX_WAIT} attempts"
    exit 1
}

# --- Argument parsing ---
sql_file=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --from)
            shift
            if [[ -z "${1:-}" ]]; then
                echo "[✗] --from requires a file path" >&2
                exit 1
            fi
            sql_file="$1"
            shift
            ;;
        --help|-h)
            echo "Usage: connect-db [--from <path-to-sql-file>]"
            exit 0
            ;;
        *)
            echo "[✗] Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# --- Container check ---
if [[ -z "${SKIP_ORACLE_CHECK:-}" ]]; then
    _check_oracle_container
fi

# --- Main ---
_setup_oracle_env
_check_ic_deps "$_oracle_bin"
wait_for_oracle

# --- Interactive credentials ---
echo -n "Username [mca]: "
read -r user
user="${user:-mca}"

echo -n "Password [mca]: "
stty -echo 2>/dev/null || true
read -r password
stty echo 2>/dev/null || true
echo ""
password="${password:-mca}"

database="$DEFAULT_HOST:$DEFAULT_PORT/$DEFAULT_SERVICE"

# --- Launch ---
tmp_script="/tmp/oracle-connect-$$.sql"
trap 'rm -f "$tmp_script"' EXIT
{
    printf "connect %s/%s@%s\n" "$user" "$password" "$database"
} > "$tmp_script"

if [[ -n "$sql_file" ]]; then
    if [[ ! -f "$sql_file" ]]; then
        echo "[✗] SQL file not found: $sql_file" >&2
        exit 1
    fi
    {
        printf "set pagesize 0 feedback off verify off heading off echo off\n"
        printf "set define off\n"
        printf "start %s\n" "$sql_file"
        printf "exit\n"
    } >> "$tmp_script"
    exec sqlplus -S /NOLOG @"$tmp_script"
else
    exec rlwrap sqlplus /NOLOG @"$tmp_script"
fi
