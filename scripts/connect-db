#!/usr/bin/env bash
# connect-db — Start Oracle container, wait for readiness, connect via SQL*Plus

set -euo pipefail

# --- Config ---
readonly CONTAINER_NAME="oracledb"
readonly CONNECT_STRING="mca/mca@localhost:1521/FREEPDB1"
readonly MAX_WAIT=60
readonly POLL_INTERVAL=2

# --- Oracle environment ---
_oracle_bin=""

_detect_distro_for_hint() {
    if [[ -r /etc/os-release ]]; then
        # shellcheck source=/dev/null
        source /etc/os-release
        echo "${ID:-unknown}"
    else
        echo "unknown"
    fi
}

_check_ic_deps() {
    local bin="$1"
    local missing
    missing="$(ldd "$bin" 2>/dev/null | grep 'not found' | awk '{print $1}' || true)"
    if [[ -n "$missing" ]]; then
        echo "[✗] Missing shared libraries for sqlplus:"
        printf '    %s\n' "$missing"
        if echo "$missing" | grep -q 'libaio'; then
            local distro
            distro="$(_detect_distro_for_hint)"
            case "$distro" in
                debian|ubuntu|linuxmint|kali)
                    echo "[>] Fix: sudo apt-get install -y libaio1"
                    ;;
                fedora)
                    echo "[>] Fix: sudo dnf install -y libaio"
                    ;;
                arch)
                    echo "[>] Fix: sudo pacman -S libaio"
                    ;;
                opensuse)
                    echo "[>] Fix: sudo zypper install -y libaio1"
                    ;;
                *)
                    echo "[>] Fix: Install the 'libaio' package for your distro"
                    ;;
            esac
        fi
        echo "[>] Or re-run: ./install.sh"
        exit 1
    fi
}

_setup_oracle_env() {
    local install_dir="${HOME}/.local/oracle"
    local ic_dir=""

    # Already on PATH?
    if command -v sqlplus &>/dev/null; then
        _oracle_bin="$(command -v sqlplus)"
        return 0
    fi

    # Find extracted instantclient dir
    ic_dir="$(find "$install_dir" -maxdepth 1 -type d -name 'instantclient_*' 2>/dev/null | head -n1)"
    if [[ -n "$ic_dir" && -x "${ic_dir}/sqlplus" ]]; then
        export ORACLE_HOME="$ic_dir"
        export LD_LIBRARY_PATH="${ic_dir}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
        export PATH="${ic_dir}:${PATH}"
        _oracle_bin="${ic_dir}/sqlplus"
        return 0
    fi

    echo "[✗] sqlplus not found. Run ./install.sh first."
    exit 1
}

# --- Container functions ---
container_running() {
    [[ "$(podman inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)" == "true" ]]
}

container_exists() {
    podman container exists "$CONTAINER_NAME" 2>/dev/null
}

start_oracle() {
    if container_running; then
        echo "[✓] Oracle container is already running"
        return 0
    fi

    if container_exists; then
        echo "[>] Starting Oracle container..."
        podman start "$CONTAINER_NAME"
    else
        echo "[✗] Oracle container does not exist. Run ./install.sh first."
        exit 1
    fi
}

wait_for_oracle() {
    echo "[>] Waiting for Oracle to accept connections..."
    local attempts=0
    while [[ $attempts -lt $MAX_WAIT ]]; do
        if podman exec "$CONTAINER_NAME" bash -c "echo 'SELECT 1 FROM DUAL;' | sqlplus -s / as sysdba" 2>/dev/null | grep -q '1'; then
            echo "[✓] Oracle is ready"
            return 0
        fi
        ((attempts++))
        sleep "$POLL_INTERVAL"
        printf "\r[>] Waiting... (%d/%d)" "$attempts" "$MAX_WAIT"
    done
    printf "\n"
    echo "[✗] Oracle did not become ready after ${MAX_WAIT} attempts"
    exit 1
}

# --- Main ---
_setup_oracle_env
_check_ic_deps "$_oracle_bin"
start_oracle
wait_for_oracle

# Hand over to rlwrap + sqlplus
exec rlwrap "${_oracle_bin:-sqlplus}" "$CONNECT_STRING"
